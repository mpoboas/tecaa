<script>
if (window.tecaaXapi) {
  var duration = window.tecaaXapi.isoDurationSinceSessionStart();
  var success = true;
  window.tecaaXapi.send(
    Object.assign(
      window.tecaaXapi.base(
        'http://adlnet.gov/expapi/verbs/completed',
        'completed'
      ),
      {
        result: {
          score: {
            raw: 1,
            min: 0,
            max: 1,
            scaled: 1
          },
          success: success,
          completion: true,
          duration: duration
        }
      }
    )
  );
}
</script>

