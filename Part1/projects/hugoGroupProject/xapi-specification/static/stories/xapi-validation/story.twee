:: Story JavaScript [script]
/* Part 1: POST only to Netlify proxy; this story keeps endpoint/credentials off client-side source. */
(function () {
  if (window.tecaaXapi) return;
  window.tecaaXapi = {};
  var PROXY_PATH = '/.netlify/functions/xapi-statement';
  var sessionStart = null;
  var LEARNER_STORAGE_KEY = 'tecaa_learner_name';

  function slugLearnerName(name) {
    return String(name || '').trim().toLowerCase().replace(/\s+/g, '.').replace(/[^a-z0-9._-]/g, '') || 'learner';
  }
  function readStoredLearnerName() {
    try {
      return sessionStorage.getItem(LEARNER_STORAGE_KEY) || '';
    } catch (e) {
      return '';
    }
  }
  function storeLearnerName(name) {
    var trimmed = String(name || '').trim();
    if (!trimmed) return '';
    try {
      sessionStorage.setItem(LEARNER_STORAGE_KEY, trimmed);
    } catch (err) {}
    return trimmed;
  }
  if (!window.__tecaaLearnerInputBound) {
    window.__tecaaLearnerInputBound = true;
    document.addEventListener(
      'input',
      function (e) {
        if (e.target && e.target.matches('tw-passage input[type="text"]')) {
          storeLearnerName(e.target.value);
        }
      },
      true
    );
  }

  window.tecaaXapi.markSessionStart = function () {
    sessionStart = new Date();
  };

  window.tecaaXapi.isoDurationSinceSessionStart = function () {
    if (!sessionStart) return 'PT0S';
    var sec = Math.max(0, Math.floor((Date.now() - sessionStart.getTime()) / 1000));
    return 'PT' + sec + 'S';
  };

  window.tecaaXapi.base = function (verbId, verbDisplay) {
    var learnerName = readStoredLearnerName();
    var actor = learnerName
      ? { name: learnerName, mbox: 'mailto:' + slugLearnerName(learnerName) + '@example.org' }
      : {
          name: 'anon-' + Math.random().toString(36).slice(2, 10),
          mbox: 'mailto:anon@example.org'
        };
    return {
      actor: actor,
      verb: {
        id: verbId,
        display: { 'en-US': verbDisplay }
      },
      object: {
        id: 'https://tecaa-group.example/xapi/validation/story',
        definition: {
          name: { 'en-US': 'xAPI Validation and IRIs (Twine)' }
        }
      },
      timestamp: new Date().toISOString(),
      version: '1.0.3'
    };
  };

  window.tecaaXapi.send = function (statement) {
    var origin = window.location.origin || '';
    var fnOrigin = origin;
    if (window.location.hostname === 'localhost' && window.location.port === '1313') {
      fnOrigin = window.location.protocol + '//' + window.location.hostname + ':8888';
    }
    var url = fnOrigin + PROXY_PATH;
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(statement)
    }).catch(function () {});
  };
})();

