:: End
(set: $steps to $steps + 1)
(set: _success to $score >= 3)

<script>
if (window.tecaaXapiOptional) {
  var duration = window.tecaaXapiOptional.isoDurationSinceSessionStart();
  var raw = Math.max(0, Math.min(4, Number((window.State && window.State.variables && window.State.variables.score) || 0)));
  var scaled = raw / 4;
  var success = raw >= 3;

  window.tecaaXapiOptional.send(
    window.tecaaXapiOptional.base(
      'http://adlnet.gov/expapi/verbs/completed',
      'completed',
      {
        result: {
          score: {
            raw: raw,
            min: 0,
            max: 4,
            scaled: scaled
          },
          success: success,
          completion: true,
          duration: duration
        }
      }
    )
  );
}
</script>

