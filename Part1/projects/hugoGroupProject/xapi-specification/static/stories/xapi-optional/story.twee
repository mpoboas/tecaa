:: Story JavaScript [script]
/* Keep xAPI credentials off the client by sending statements only through the serverless proxy. */
(function () {
  if (window.tecaaXapiOptional) return;

  window.tecaaXapiOptional = {};

  var PROXY_PATH = '/.netlify/functions/xapi-statement';
  var sessionStart = null;
  var LEARNER_STORAGE_KEY = 'tecaa_learner_name';

  function slugLearnerName(name) {
    return String(name || '').trim().toLowerCase().replace(/\s+/g, '.').replace(/[^a-z0-9._-]/g, '') || 'learner';
  }
  function readStoredLearnerName() {
    try {
      return sessionStorage.getItem(LEARNER_STORAGE_KEY) || '';
    } catch (e) {
      return '';
    }
  }
  function storeLearnerName(name) {
    var trimmed = String(name || '').trim();
    if (!trimmed) return '';
    try {
      sessionStorage.setItem(LEARNER_STORAGE_KEY, trimmed);
    } catch (err) {}
    return trimmed;
  }
  if (!window.__tecaaLearnerInputBound) {
    window.__tecaaLearnerInputBound = true;
    document.addEventListener(
      'input',
      function (e) {
        if (e.target && e.target.matches('tw-passage input[type="text"]')) {
          storeLearnerName(e.target.value);
        }
      },
      true
    );
  }

  function pageOrigin() {
    return typeof location !== 'undefined' && location.origin ? location.origin : '';
  }

  function proxyOrigin() {
    if (typeof location === 'undefined' || !location.hostname) return '';
    if (location.hostname === 'localhost' && location.port === '1313') {
      return location.protocol + '//' + location.hostname + ':8888';
    }
    return pageOrigin();
  }

  window.tecaaXapiOptional.markSessionStart = function () {
    sessionStart = new Date();
  };

  window.tecaaXapiOptional.isoDurationSinceSessionStart = function () {
    if (!sessionStart) return 'PT0S';
    var sec = Math.max(0, Math.floor((Date.now() - sessionStart.getTime()) / 1000));
    return 'PT' + sec + 'S';
  };

  window.tecaaXapiOptional.base = function (verbId, verbDisplay, extra) {
    var learnerName = readStoredLearnerName();
  var actor = learnerName
      ? { name: learnerName, mbox: 'mailto:' + slugLearnerName(learnerName) + '@example.org' }
      : {
          name: 'anon-' + Math.random().toString(36).slice(2, 10),
          mbox: 'mailto:anon@example.org'
        };
    var statement = {
      actor: actor,
      verb: {
        id: verbId,
        display: { 'en-US': verbDisplay }
      },
      object: {
        id: pageOrigin() + '/stories/xapi-optional/',
        definition: {
          name: { 'en-US': 'xAPI Optional Fields Quiz (Twine)' },
          description: {
            'en-US': 'Simple quiz about when to use optional xAPI fields.'
          }
        }
      },
      timestamp: new Date().toISOString(),
      version: '1.0.3'
    };

    if (extra && typeof extra === 'object') {
      Object.keys(extra).forEach(function (key) {
        statement[key] = extra[key];
      });
    }

    return statement;
  };

  window.tecaaXapiOptional.send = function (statement) {
    var url = proxyOrigin() + PROXY_PATH;
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(statement)
    }).catch(function () {});
  };
})();

:: Start
(set: $score to 0)
(set: $steps to 1)
(set: $learner_name to "")

Welcome to the **xAPI Optional Fields Quiz**.

You will answer 4 quick questions:
- `result`
- `context`
- `timestamp`
- `authority`

Each correct answer gives 1 point.

What is your name?

(input: bind $learner_name)

(live: 0.5s)[
(if: (trimmed: $learner_name) is not "")[
[[Begin quiz->Q1]]
](else:)[
Enter your name to continue.
]
]

:: Q1
(set: $steps to $steps + 1)

<script>
if (window.tecaaXapiOptional) {
  window.tecaaXapiOptional.markSessionStart();
  window.tecaaXapiOptional.send(
    window.tecaaXapiOptional.base(
      'http://adlnet.gov/expapi/verbs/initialized',
      'initialized'
    )
  );
}
</script>

What is the best use case for `result`?

[[A quiz where you want to send score and success->Q1Right]]
[[Opening a static page with no evaluation->Q1Wrong]]

:: Q1Right
(set: $steps to $steps + 1)
(set: $score to $score + 1)

<script>
if (window.tecaaXapiOptional) {
  window.tecaaXapiOptional.send(
    window.tecaaXapiOptional.base(
      'http://adlnet.gov/expapi/verbs/responded',
      'responded',
      {
        result: {
          success: true,
          completion: false,
          response: 'q1-correct-result'
        }
      }
    )
  );
}
</script>

Correct.

[[Next question->Q2]]

