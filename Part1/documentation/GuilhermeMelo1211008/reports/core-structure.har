 href=\"https://github.com/nextapps-de/flexsearch\">FlexSearch</a></p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n\r\n    <div class=\"wrap container-fluid\" role=\"document\">\r\n      <div class=\"content\">\r\n      \r\n        \r\n\t<div class=\"row flex-xl-nowrap\">\r\n\t\t<div class=\"col-lg-5 col-xl-4 docs-sidebar d-none d-lg-block\">\r\n\t\t\t\r\n  \r\n    \r\n<nav class=\"section-nav docs-links\">\r\n  <ul class=\"list-unstyled\">\r\n\r\n  <li>\r\n    <details open>\r\n      <summary>xAPI</summary>\r\n      <ul class=\"list-unstyled list-nested\">\r\n\r\n  <li>\r\n      <a href=\"/docs/xapi/fundamentals/\">Fundamentals</a>\r\n  </li>\r\n\r\n  <li class=\"active\" >\r\n      <a aria-current=\"page\" href=\"/docs/xapi/structure/\">Core Structure</a>\r\n  </li>\r\n\r\n  <li>\r\n      <a href=\"/docs/xapi/optional-fields/\">Optional Fields</a>\r\n  </li>\r\n\r\n  <li>\r\n      <a href=\"/docs/xapi/validation/\">Validation and IRIs</a>\r\n  </li>\r\n      </ul>\r\n    </details>\r\n  </li>\r\n  </ul>\r\n</nav>\r\n\r\n  \r\n\r\n\t\t</div>\r\n\t\t\r\n\t\t\t<div class=\"col container-fw d-lg-flex flex-lg-row justify-content-center mx-auto\">\r\n\t\t\r\n\t\t<nav class=\"docs-toc d-none d-xl-block col-xl-3\" aria-label=\"Secondary navigation\">\r\n\t\t\t<div class=\"page-links\">\r\n  <h3>On this page</h3>\r\n    <nav id=\"toc\">\n  <ul>\n    <li><a href=\"#overview\">Overview</a></li>\n    <li><a href=\"#statement-model\">Statement Model</a></li>\n    <li><a href=\"#mandatory-fields\">Mandatory Fields</a>\n      <ul>\n        <li><a href=\"#actor\">Actor</a></li>\n        <li><a href=\"#verb\">Verb</a></li>\n        <li><a href=\"#object\">Object</a></li>\n        <li><a href=\"#version\">Version</a></li>\n      </ul>\n    </li>\n    <li><a href=\"#json-examples\">JSON Examples</a>\n      <ul>\n        <li><a href=\"#valid-statement-example\">Valid Statement Example</a></li>\n        <li><a href=\"#invalid-statement-example\">Invalid Statement Example</a></li>\n      </ul>\n    </li>\n    <li><a href=\"#validation-rules\">Validation Rules</a></li>\n    <li><a href=\"#interactive-module\">Interactive Module</a></li>\n  </ul>\n</nav>\r\n</div>\r\n\r\n\t\t</nav>\r\n\t\t<main class=\"docs-content col-lg-16 col-xl-9\">\r\n\t\t<nav class=\"toc-mobile toc-mobile-sticky d-xl-none\" aria-label=\"Quaternary navigation\">\r\n\t\t\t\t<details>\r\n    <summary>On this page</summary>\r\n    <div class=\"page-links\">\r\n      <nav id=\"TableOfContents\">\n  <ul>\n    <li><a href=\"#overview\">Overview</a></li>\n    <li><a href=\"#statement-model\">Statement Model</a></li>\n    <li><a href=\"#mandatory-fields\">Mandatory Fields</a>\n      <ul>\n        <li><a href=\"#actor\">Actor</a></li>\n        <li><a href=\"#verb\">Verb</a></li>\n        <li><a href=\"#object\">Object</a></li>\n        <li><a href=\"#version\">Version</a></li>\n      </ul>\n    </li>\n    <li><a href=\"#json-examples\">JSON Examples</a>\n      <ul>\n        <li><a href=\"#valid-statement-example\">Valid Statement Example</a></li>\n        <li><a href=\"#invalid-statement-example\">Invalid Statement Example</a></li>\n      </ul>\n    </li>\n    <li><a href=\"#validation-rules\">Validation Rules</a></li>\n    <li><a href=\"#interactive-module\">Interactive Module</a></li>\n  </ul>\n</nav>\r\n    </div>\r\n  </details>\r\n\r\n\t\t\t</nav>\r\n\t\t\t\r\n\t\t\t<div class=\"page-header d-flex flex-row justify-content-between align-items-start\">\r\n\t\t\t\t<div>\r\n\t\t\t\t\t<h1>Core Structure</h1>\r\n\t\t\t\t\t\r\n\t\t\t\t</div>\r\n\t\t\t\t<div>\r\n\t\t\t\t\t<div id=\"ai-dropdown\" class=\"dropdown\">\r\n  <button class=\"btn btn-sm dropdown-toggle\" type=\"button\" data-bs-toggle=\"dropdown\" data-bs-auto-close=\"outside\" aria-expanded=\"false\">\r\n    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"i